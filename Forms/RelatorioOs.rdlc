<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"
        xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="DataSetRelatorio">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>DataSetRelatorio</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSetRelatorio">
      <Query>
        <DataSourceName>DataSetRelatorio</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="ClienteNome">
          <DataField>ClienteNome</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OsId">
          <DataField>OsId</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DataAbertura">
          <DataField>DataAbertura</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Status">
          <DataField>Status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ValorTotal">
          <DataField>ValorTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotalImpostos">
          <DataField>TotalImpostos</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <Body>
    <ReportItems>

      <Textbox Name="txtTitulo">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Relatório de Ordens de Serviço</Value>
                <Style>
                  <FontSize>14pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
          </Paragraph>
        </Paragraphs>
        <Style>
          <TextAlign>Center</TextAlign>
        </Style>
        <Top>0cm</Top>
        <Left>0cm</Left>
        <Height>0.8cm</Height>
        <Width>17cm</Width>
      </Textbox>

      <Textbox Name="txtSubtitulo">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Ordens de Serviço por Período</Value>
                <Style>
                  <FontSize>10pt</FontSize>
                </Style>
              </TextRun>
            </TextRuns>
          </Paragraph>
        </Paragraphs>
        <Style>
          <TextAlign>Center</TextAlign>
        </Style>
        <Top>0.9cm</Top>
        <Left>0cm</Left>
        <Height>0.5cm</Height>
        <Width>17cm</Width>
      </Textbox>

      <Tablix Name="Tablix1">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>5cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>

            <!-- Cabeçalho: Navy + texto branco + negrito -->
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="hCliente">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>Cliente</Value>
                        <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>Navy</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Center</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="hAbertura">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>Abertura</Value>
                        <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>Navy</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Center</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="hStatus">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>Status</Value>
                        <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>Navy</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Center</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="hValorTotal">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>Valor Total</Value>
                        <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>Navy</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Center</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="hImpostos">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>Impostos</Value>
                        <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>Navy</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Center</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
              </TablixCells>
            </TablixRow>

            <!-- Detalhe: fundo branco, borda cinza -->
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="dCliente">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Fields!ClienteNome.Value</Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>White</BackgroundColor>
                        <Border><Color>LightGrey</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="dAbertura">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Format(CDate(Fields!DataAbertura.Value),"dd/MM/yyyy")</Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>White</BackgroundColor>
                        <Border><Color>LightGrey</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Center</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="dStatus">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Switch(Fields!Status.Value="EmAndamento","Em Andamento",Fields!Status.Value="Concluida","Concluída",Fields!Status.Value="Cancelada","Cancelada",True,Fields!Status.Value)</Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>White</BackgroundColor>
                        <Border><Color>LightGrey</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="dValorTotal">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Format(Fields!ValorTotal.Value,"R$ #,##0.00")</Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>White</BackgroundColor>
                        <Border><Color>LightGrey</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Right</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="dImpostos">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Format(Fields!TotalImpostos.Value,"R$ #,##0.00")</Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>White</BackgroundColor>
                        <Border><Color>LightGrey</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Right</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
              </TablixCells>
            </TablixRow>

            <!-- Total geral: 5 células explícitas (sem ColSpan) -->
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="tTotalLabel">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>TOTAL GERAL</Value>
                        <Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>LightGrey</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="tTotalVazio1">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value></Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>LightGrey</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="tTotalVazio2">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value></Value>
                        <Style><FontSize>9pt</FontSize></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>LightGrey</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="tTotalValor">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Format(Sum(Fields!ValorTotal.Value),"R$ #,##0.00")</Value>
                        <Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>LightGrey</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Right</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="tTotalImpostos">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun>
                        <Value>=Format(Sum(Fields!TotalImpostos.Value),"R$ #,##0.00")</Value>
                        <Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style>
                      </TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style>
                        <BackgroundColor>LightGrey</BackgroundColor>
                        <Border><Color>Black</Color><Style>Solid</Style><Width>0.5pt</Width></Border>
                        <TextAlign>Right</TextAlign>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
              </TablixCells>
            </TablixRow>

          </TablixRows>
        </TablixBody>
        <TablixColumnHierarchy>
          <TablixMembers>
            <TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/>
          </TablixMembers>
        </TablixColumnHierarchy>
        <TablixRowHierarchy>
          <TablixMembers>
            <TablixMember/>
            <TablixMember>
              <Group Name="Details1"/>
            </TablixMember>
            <TablixMember/>
          </TablixMembers>
        </TablixRowHierarchy>
        <DataSetName>DataSetRelatorio</DataSetName>
        <Top>1.6cm</Top>
        <Left>0cm</Left>
        <Width>17cm</Width>
      </Tablix>

      <Textbox Name="txtTotalOs">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="Total de OS no período: " &amp; Count(Fields!OsId.Value, "DataSetRelatorio")</Value>
                <Style>
                  <FontSize>9pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
          </Paragraph>
        </Paragraphs>
        <Top>5cm</Top>
        <Left>0cm</Left>
        <Height>0.6cm</Height>
        <Width>17cm</Width>
      </Textbox>

    </ReportItems>
    <Height>20cm</Height>
  </Body>
  <Width>17cm</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin>
    <RightMargin>2cm</RightMargin>
    <TopMargin>2cm</TopMargin>
    <BottomMargin>2cm</BottomMargin>
  </Page>
</Report>
